# ─────────────────────────────────────────────────────────────────────────────
# MYXON Platform — Environment variables reference
#
# НЕ ЗАПОЛНЯЙ ЭТОТ ФАЙЛ ВРУЧНУЮ.
# Используй: sudo bash deploy.sh --domain myxon.yourcompany.com
# Скрипт автоматически генерирует .env с безопасными паролями.
#
# Этот файл (.env.example) — только для справки. Безопасно коммитить в git.
# Файл .env — секреты, НИКОГДА не коммить в git (он в .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_HOST=myxon.yourcompany.com
APP_BASE_URL=https://myxon.yourcompany.com

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=GENERATED_BY_DEPLOY_SCRIPT

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=GENERATED_BY_DEPLOY_SCRIPT

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
SECRET_KEY=GENERATED_BY_DEPLOY_SCRIPT

# ─── First admin user ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=GENERATED_BY_DEPLOY_SCRIPT

# ─── FRPS ─────────────────────────────────────────────────────────────────────
FRPS_BIND_PORT=7000
TUNNEL_PORT_START=10000
TUNNEL_PORT_END=10100
FRPS_PLUGIN_SECRET=GENERATED_BY_DEPLOY_SCRIPT

# ─── Email notifications (SMTP) ───────────────────────────────────────────────
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=noreply@yourcompany.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@yourcompany.com
SMTP_USE_TLS=true

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info
UVICORN_WORKERS=2
