# ─────────────────────────────────────────────────────────────────────────────
# MYXON Edge Agent — конфиг
#
# Агент запускается на роутере/Orange Pi и делает три вещи:
#   1. Сканирует LAN-интерфейс → находит контроллеры сам (авто-дискавери)
#   2. Регистрируется на MYXON сервере по белому адресу
#   3. Запускает frpc → пробивает обратный тоннель к серверу
#
# Минимальная конфигурация — две строки:
#   MYXON_CLOUD_URL и MYXON_SERIAL
#   Всё остальное агент определяет сам.
#
# Запуск:
#   python myxon_agent.py          # подхватывает agent.env автоматически
#   sudo systemctl start myxon-agent  # через systemd
# ─────────────────────────────────────────────────────────────────────────────

# ── Обязательно ────────────────────────────────────────────────────────────────

# Белый адрес MYXON сервера (в dev — IP мака в LAN, в prod — публичный IP/домен)
MYXON_CLOUD_URL=http://MY_SERVER_IP:8000

# Серийный номер устройства (должен быть предварительно внесён в БД сервера)
# Демо-серийники из seed: HOTRACO-ORN-001, HOTRACO-ORN-002, HOTRACO-SIR-001
MYXON_SERIAL=HOTRACO-ORN-001

# ── Опционально ────────────────────────────────────────────────────────────────

MYXON_AGENT_ID=agent-001
MYXON_AGENT_SECRET=dev-secret

# Как часто слать heartbeat на сервер (секунды)
MYXON_HEARTBEAT_INTERVAL=15

# Как часто повторно сканировать LAN (секунды)
MYXON_DISCOVERY_INTERVAL=60

# Путь к frpc (устанавливается через setup-debian.sh)
MYXON_FRPC_BIN=frpc

# ── frpc токен (НЕ задавать вручную) ───────────────────────────────────────────
# Агент получает уникальный per-device токен при первой регистрации на сервере
# и сохраняет его в /etc/myxon/agent_token (права 0600).
# Изменить путь: MYXON_TOKEN_FILE=/etc/myxon/agent_token
# СТАРЫЙ параметр MYXON_FRPS_TOKEN удалён — больше не используется.

# ── Режим сканирования LAN ──────────────────────────────────────────────────────
# auto (по умолчанию)
#   Сначала ищет выделенные LAN-интерфейсы (eth1, eth2...). Если их нет —
#   автоматически сканирует подсеть основного интерфейса (eth0).
#   Подходит для случая: "Orange Pi вставлен в существующую LAN фермы (камеры)".
#
# lan-only
#   Сканирует только не-WAN интерфейсы. Подходит, когда Orange Pi — роутер
#   с отдельным LAN-портом. Никогда не трогает WAN-подсеть.
#
# all
#   Сканирует все интерфейсы включая WAN. Явный эквивалент auto-fallback.
#
MYXON_SCAN_MODE=auto

# ── Ручной override (если авто-дискавери не нужен) ─────────────────────────────
# Если задан — агент использует этот список и LAN не сканирует.
# Оставь закомментированным для авто-режима.
#
# MYXON_RESOURCES=[{"id":"remote-plus","protocol":"tcp","host":"192.168.1.100","port":5843,"name":"Remote+"}]
