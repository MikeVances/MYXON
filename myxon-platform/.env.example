# ─────────────────────────────────────────────────────────────────────────────
# MYXON Platform — конфигурация VPS
#
# Использование:
#   cp .env.example .env
#   nano .env   # заполнить CHANGE_ME
#
# Генерация случайных секретов:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ── Адрес сервера ─────────────────────────────────────────────────────────────
# Публичный IP или домен VPS. Если Tailscale — Tailscale IP (100.x.x.x)
SERVER_HOST=CHANGE_ME

# URL для invite-ссылок и CORS. С доменом: https://myxon.example.com
APP_BASE_URL=http://CHANGE_ME

# ── Секреты ───────────────────────────────────────────────────────────────────
# JWT подпись: openssl rand -hex 32
SECRET_KEY=CHANGE_ME

# Пароль PostgreSQL
DB_PASSWORD=CHANGE_ME

# Пароль Redis
REDIS_PASSWORD=CHANGE_ME

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=myxon
POSTGRES_DB=myxon
# DB_PASSWORD задаётся выше

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_PASSWORD задаётся выше

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── frps туннель ──────────────────────────────────────────────────────────────
FRPS_BIND_PORT=7000
FRPS_DASHBOARD_PORT=7500
TUNNEL_PORT_START=10000
TUNNEL_PORT_END=10100

# ── Guacamole ─────────────────────────────────────────────────────────────────
GUACD_HOST=guacd
GUACD_PORT=4822

# ── Frontend (nginx, пустой = same-origin) ────────────────────────────────────
VITE_API_URL=

# ── Прочее ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# UVICORN_WORKERS=2
